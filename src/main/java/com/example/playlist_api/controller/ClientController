package com.example.playlist_api.controller;

import org.springframework.web.bind.annotation.*;

import com.example.playlist_api.dto.CreateClientRequest;
import com.example.playlist_api.entity.Client;
import com.example.playlist_api.service.ClientService;

@RestController
@RequestMapping("/clients")
public class ClientController {

    private final ClientService clientService;

    public ClientController(ClientService clientService) {
        this.clientService = clientService;
    }

    @PostMapping
    public Client createClient(@RequestBody CreateClientRequest request) {
        return clientService.createClient(request.getUsername());
    }

    @GetMapping("/{id}")
    public Client getClient(@PathVariable int id) {
        return clientService.getClientOrThrow(id);
    }

}